# ─── Python ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.Python
build/
dist/

# ─── Virtual environments ───────────────────────────────
venv/
.venv/
env/

# ─── Environment / secrets ──────────────────────────────
.env
.env.*

# ─── Streamlit ──────────────────────────────────────────
.streamlit/secrets.toml

