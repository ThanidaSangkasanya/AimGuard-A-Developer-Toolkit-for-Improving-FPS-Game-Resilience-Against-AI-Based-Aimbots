# Copy this file to ".env" and adjust the paths below to match your machine.
# ".env" itself is git-ignored — never commit your real .env file.

# Path to the NanoDet repository + weights (see install guide, step 6)
NANODET_ROOT=third_party/nanodet

# Optional fallback dataset root. Not required if you always run through
# the dashboard or the .bat scripts (they pass --data_path explicitly).
# DATASET_ROOT=data